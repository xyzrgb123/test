--инициализация
init

-- инициализация аккаунта
config --global user.email "xyzrgb123@gmail.com"
config --global user.name "Alex"

--добавить адрес репозитория
remote add origin {link}

--посмотреть конфигурацию
config --list

--добавить все файлы
add .

--публикация изменений в текущей ветке
push

--принять изменения с сети
pull

--клонировать репозиторий на компьютер
clone {link}









*** КОММИТЫ ***

--добавить снимок состояния (коммит), с указанием имени коммита
commit -m "имя снимка"

--инфа об изменениях с последнего коммита
status

--инфа в кратком виде об изменениях с последнего коммита
status --short

--переместить голову на 2 коммитов назад
checkout HEAD~2

--переместить из добавленной зоны в обычную
reset .

--откатиться на один коммит, с удалением изменений
reset --hard HEAD^1

--откатиться на один коммит, с перемещением изменений в add-зону
reset --soft HEAD^1

--отменить изменения в файле
checkout -- {file}

--отменить изменения во всех файлах
checkout -- .

--перейти к коммиту по хешу
checkout {hesh}








*** ВЕТКИ ***

--создать новую ветку
branch {name}

--создать ветку и сразу перейти в нее
chechout -b {name}

--перейти к ветке по ее имени
chechout {name}

--переименовать не текущую ветку
branch -m {old_name} {new_name}

--переименовать текущую ветку
branch -m main

--удалить ветку по имени
branch -d {name}

--публикация изменений в конкретной ветке
push origin main

--прибавить ветку к текущей (объединить)
merge {name}

